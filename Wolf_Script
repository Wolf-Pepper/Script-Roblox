    espEnabled = not espEnabled
    if espEnabled then
        espBox.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
        espLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= localPlayer and player.Character then applyHighlight(player.Character) end
        end
    else
        espBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        espLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Character then removeHighlight(player.Character) end
